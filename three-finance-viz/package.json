{
  "name": "three-finance-viz",
  "version": "1.0.3",
  "description": "3D financial visualization library built on Three.js",
  "type": "module",
  "main": "./dist/three-finance-viz.umd.js",
  "module": "./dist/three-finance-viz.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/three-finance-viz.es.js",
      "require": "./dist/three-finance-viz.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "three": "^0.172.0",
    "three-stdlib": "^2.35.0",
    "postprocessing": "^6.36.3",
    "troika-three-text": "^0.49.1",
    "d3-scale": "^4.0.2",
    "d3-array": "^3.2.4",
    "d3-color": "^3.1.0",
    "d3-interpolate": "^3.0.1"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-array": "^3.2.1",
    "@types/d3-color": "^3.1.3",
    "@types/d3-interpolate": "^3.0.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5",
    "@vitest/coverage-v8": "^3.0.5"
  }
}
